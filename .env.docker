# Docker环境配置文件
# 复制此文件为.env并根据实际情况修改配置

# ============ 基础配置 ============
PROJECT_NAME=zhiweijz
NODE_ENV=production
DOCKER_ENV=true

# ============ 数据库配置 ============
POSTGRES_IMAGE_VERSION=15-alpine
DB_NAME=zhiweijz
DB_USER=postgres
DB_PASSWORD=postgres123
DB_HOST=postgres
DB_PORT=5432
DB_TIMEZONE=UTC
POSTGRES_EXTERNAL_PORT=5432

# ============ JWT配置 ============
JWT_SECRET=your_jwt_secret_change_in_production_very_important

# ============ 后端服务配置 ============
BACKEND_PORT=3000
BACKEND_IMAGE_VERSION=latest

# ============ 微信公众号配置 ============
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=
WECHAT_ENCODING_AES_KEY=
WECHAT_ENV=production
WECHAT_DEV_APP_ID=
WECHAT_DEV_APP_SECRET=
WECHAT_DEV_TOKEN=

# ============ 文件存储配置 ============
FILE_MAX_SIZE=10485760
FILE_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,audio/mpeg,audio/wav,audio/ogg

# ============ MinIO对象存储配置 ============
MINIO_IMAGE_VERSION=latest
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BROWSER_REDIRECT_URL=
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============ RevenueCat支付配置 ============
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_REST_API_KEY=
NEXT_PUBLIC_REVENUECAT_API_KEY=

# ============ 会员系统配置 ============
ENABLE_MEMBERSHIP_SYSTEM=true
ENABLE_ACCOUNTING_POINTS_SYSTEM=true
MEMBERSHIP_MONTHLY_POINTS=1000
DEFAULT_MEMBER_TYPE=free

# ============ 版本管理系统配置 ============
ENABLE_VERSION_MANAGEMENT=true
VERSION_CHECK_API_ENABLED=true
VERSION_CHECK_INTERVAL=3600000
FORCE_UPDATE_GRACE_PERIOD=259200
UPDATE_NOTIFICATION_ENABLED=true

# ============ 计划任务配置 ============
USE_UNIFIED_SCHEDULER=true

# ============ 邮件服务配置 ============
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ============ AI服务配置 ============
OPENAI_API_KEY=

# ============ 前端服务配置 ============
FRONTEND_PORT=3003
FRONTEND_IMAGE_VERSION=latest
NEXT_PUBLIC_APP_VERSION=0.9.1
NEXT_PUBLIC_BUILD_NUMBER=1
BUILD_MODE=web
NEXT_PUBLIC_IS_MOBILE=false
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DEBUG_API_BASE_URL=
NEXT_PUBLIC_OFFICIAL_WEBSITE=https://zhiweijz.cn

# ============ 前端版本管理配置 ============
NEXT_PUBLIC_ENABLE_VERSION_CHECK=true
NEXT_PUBLIC_VERSION_CHECK_INTERVAL=3600000
NEXT_PUBLIC_AUTO_VERSION_CHECK=true

# ============ 前端日志配置 ============
NEXT_PUBLIC_ENABLE_CONSOLE_LOGS=false
NEXT_PUBLIC_LOG_LEVEL=error
NEXT_PUBLIC_PRESERVE_ERROR_LOGS=true
NEXT_PUBLIC_ALLOW_RUNTIME_LOG_CONTROL=false

# ============ Next.js遥测配置 ============
NEXT_TELEMETRY_DISABLED=1

# ============ Nginx配置 ============
NGINX_IMAGE_VERSION=latest
EXTERNAL_DOMAIN=localhost
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
